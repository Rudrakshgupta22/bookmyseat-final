{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "functions": {
    "bookmyseat/wsgi.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/bookmyseat/wsgi.py"
    }
  ]
}
